# Copy to .env and fill in real values:  cp .env.example .env

SARVAM_API_KEY=

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=
# GEMINI_MODEL=models/gemini-1.5-flash-latest

# Groq API (optional backup)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Frontend (Docker build uses this; use your public API URL for ngrok/production)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Database connections for order-support lookup
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE
FARMER_ENGAGEMENT_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# Optional DB tuning for schema variations
ORDERS_PHONE_COL=phone
ORDER_STATUS_HISTORY_STATUS_COL=new_status
ORDER_STATUS_HISTORY_CHANGED_AT_COL=changed_at
